# =========================================================================
# AURAWEAR — ENVIRONMENT VARIABLE CONFIGURATION (LIVE ENGINE SETUP)
# =========================================================================
# Copy this file to `.env.local` to enable live APIs.
# If these variables are not provided, Aurawear automatically runs in
# Simulated Mode, saving everything to localStorage and running simulated AI hooks.

# --- SUPABASE CONFIGURATION ---
# Found in Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- OPENAI CONFIGURATION (VISION API) ---
# Needed for analyzing wardrobe item uploads and generating outfit formulas
OPENAI_API_KEY=sk-proj-...

# --- CLOUDINARY CONFIGURATION (IMAGE BUCKET) ---
# Required for uploading and serving images in production
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
